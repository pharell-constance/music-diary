// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   
  pseudo    String
  role      String   @default("USER") 
  spotifyId String?  
  spotifyAccessToken String? @db.Text
  spotifyRefreshToken String? @db.Text
  spotifyTokenExpiresAt DateTime?
  avatar    String?  @db.LongText
  reviews   Review[] 

  followers Follows[] @relation("following")
  following Follows[] @relation("followers")

  filedReports    Report[] @relation("filedReports")
  receivedReports Report[] @relation("reportedUsers")

  warningsCount Int      @default(0)
  isBanned      Boolean  @default(false)
  banReason     String?

  notifications Notification[]
  likes         Like[]
  comments      Comment[]
  lyricPins     LyricPin[]
}

model Review {
  id             Int      @id @default(autoincrement())
  content        String
  rating         Int      
  spotifyAlbumId String  
  albumName      String   @default("")
  artistName     String   @default("")
  albumCover     String   @default("")
  createdAt      DateTime @default(now())
  
  author         User     @relation(fields: [authorId], references: [id])
  authorId       Int
  reports        Report[]
  likes          Like[]
  comments       Comment[]
}

model Follows {
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower    User     @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Report {
  id               Int      @id @default(autoincrement())
  reason           String
  createdAt        DateTime @default(now())
  resolved         Boolean  @default(false)

  reporter         User     @relation("filedReports", fields: [reporterId], references: [id])
  reporterId       Int

  reportedReview   Review?  @relation(fields: [reportedReviewId], references: [id], onDelete: Cascade)
  reportedReviewId Int?

  reportedUser     User?    @relation("reportedUsers", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reportedUserId   Int?
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
}

model Like {
  userId    Int
  reviewId  Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now())
  userId    Int
  reviewId  Int

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model LyricPin {
  id         Int      @id @default(autoincrement())
  lyric      String   @db.Text
  trackName  String
  artistName String
  albumCover String?  @db.LongText
  color      String   @default("#1DB954")
  createdAt  DateTime @default(now())

  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId   Int
}